{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (no gateways)",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "all-gateways",
      "displayName": "All gateways enabled",
      "inherits": "default",
      "cacheVariables": {
        "BUILD_GATEWAY_ICEORYX2": "ON",
        "BUILD_GATEWAY_MQTT": "ON",
        "BUILD_GATEWAY_GRPC": "ON",
        "BUILD_GATEWAY_ROS2": "ON",
        "BUILD_GATEWAY_ZENOH": "ON",
        "BUILD_GATEWAY_DBUS": "ON",
        "BUILD_GATEWAY_DDS": "ON"
      }
    },
    {
      "name": "iceoryx2",
      "displayName": "iceoryx2 gateway only",
      "inherits": "default",
      "cacheVariables": { "BUILD_GATEWAY_ICEORYX2": "ON" }
    },
    {
      "name": "mqtt",
      "displayName": "MQTT gateway only",
      "inherits": "default",
      "cacheVariables": { "BUILD_GATEWAY_MQTT": "ON" }
    },
    {
      "name": "grpc",
      "displayName": "gRPC gateway only",
      "inherits": "default",
      "cacheVariables": { "BUILD_GATEWAY_GRPC": "ON" }
    },
    {
      "name": "ros2",
      "displayName": "ROS2 gateway only",
      "inherits": "default",
      "cacheVariables": { "BUILD_GATEWAY_ROS2": "ON" }
    },
    {
      "name": "zenoh",
      "displayName": "Zenoh gateway only",
      "inherits": "default",
      "cacheVariables": { "BUILD_GATEWAY_ZENOH": "ON" }
    },
    {
      "name": "dbus",
      "displayName": "D-Bus gateway only",
      "inherits": "default",
      "cacheVariables": { "BUILD_GATEWAY_DBUS": "ON" }
    },
    {
      "name": "dds",
      "displayName": "DDS gateway only",
      "inherits": "default",
      "cacheVariables": { "BUILD_GATEWAY_DDS": "ON" }
    },
    {
      "name": "release",
      "displayName": "Release build (no gateways)",
      "inherits": "default",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "default",      "configurePreset": "default" },
    { "name": "all-gateways", "configurePreset": "all-gateways" },
    { "name": "iceoryx2",     "configurePreset": "iceoryx2" },
    { "name": "mqtt",         "configurePreset": "mqtt" },
    { "name": "grpc",         "configurePreset": "grpc" },
    { "name": "ros2",         "configurePreset": "ros2" },
    { "name": "zenoh",        "configurePreset": "zenoh" },
    { "name": "dbus",         "configurePreset": "dbus" },
    { "name": "dds",          "configurePreset": "dds" }
  ],
  "testPresets": [
    { "name": "default", "configurePreset": "default", "output": { "outputOnFailure": true } }
  ]
}
